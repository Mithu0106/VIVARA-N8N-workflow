    {
      "parameters": {
        "jsCode": "const out = [];\n\nfor (const item of items) {\n  if (!item.binary || !item.binary.attachment_0) {\n    throw new Error(\"No binary data found in item.binary.attachment_0\");\n  }\n\n  const att = item.binary.attachment_0;\n\n  out.push({\n    json: {\n      lang: 'eng+mal',\n      filename: att.fileName\n    },\n    binary: {\n      file: att   // ✅ keep binary under \"file\"\n    }\n  });\n}\n\nreturn out;\n"
      },
