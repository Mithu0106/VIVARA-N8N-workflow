    {
      "parameters": {
        "jsCode": "const output = [];\n\n// Parse the AI JSON string\nconst aiOutputStr = items[0].json.message.content;\nlet aiData = {};\ntry {\n    aiData = JSON.parse(aiOutputStr);\n} catch (err) {\n    throw new Error(\"Failed to parse AI output JSON: \" + err.message);\n}\n\n// aiData now has: summary (array), department (array), urgency, decision_support\nconst summaries = aiData.summary || [];\nconst departments = aiData.department || [];\nconst urgency = aiData.urgency || \"Normal\";\nconst decisionSupport = aiData.decision_support || \"\";\n\n// Map each department to its items\ndepartments.forEach((dept, index) => {\n    const task = summaries[index] || \"\";\n    \n    // Map department to actual email\n    let email = \"\";\n    switch(dept.toLowerCase()) {\n        case \"engineering\":\n            email = \"kmrlengineer@gmail.com\";\n            break;\n        case \"safety\":\n            email = \"kmrlsafety@gmail.com\";\n            break;\n        case \"hr\":\n            email = \"kmrlhr@gmail.com\";\n            break;\n        case \"finance\":\n            email = \"kmrlfinance@gmail.com\";\n            break;\n        default:\n            email = \"controlroom@kmrl.in\";\n    }\n\n    output.push({\n        json: {\n            department: dept,                    \n            email: email,\n            subject: `[${urgency.toUpperCase()}] KMRL Update - ${dept.toUpperCase()}`,\n            body: `Dear ${dept.toUpperCase()} Team,\\n\\nAction Item:\\n- ${task}\\n\\nDecision Support: ${decisionSupport}\\n\\nRegards,\\nKMRL AI Assistant`\n        }\n    });\n});\n\nreturn output;\n\n\n"
      },
