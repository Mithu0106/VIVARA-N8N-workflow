    {
      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of items) {\n  // Email attachments (array)\n  if (item.json.attachments) {\n    for (const att of item.json.attachments) {\n      const filename = att.fileName || 'email_file';\n      const ext = (filename.split('.').pop() || '').toLowerCase();\n      output.push({\n        json: {\n          filename,\n          source: 'email',\n          fileType: ext,\n          mimeType: att.mimeType || ''\n        },\n        binary: {\n          data: {\n            data: att.data,            // base64\n            mimeType: att.mimeType || 'application/octet-stream',\n            fileName: filename\n          }\n        }\n      });\n    }\n  }\n  // Webhook/manual upload (binary.file)\n  else if (item.binary && item.binary.file) {\n    const file = item.binary.file;\n    const filename = file.fileName || 'uploaded_file';\n    const ext = (filename.split('.').pop() || '').toLowerCase();\n    output.push({\n      json: {\n        filename,\n        source: 'webhook',\n        fileType: ext,\n        mimeType: file.mimeType || ''\n      },\n      binary: {\n        data: file\n      }\n    });\n  }\n}\n\nreturn output;\n"
      },
